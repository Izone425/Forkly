# Dev defaults (committed, loaded by Vite in dev mode).
# Base URL of the Forkly .NET API. This is also the default in src/config.js,
# so it's only here to make the value explicit for collaborators.
VITE_API_BASE=http://localhost:5080

# Base URL of Amirul's MENU microservice (Forkly-MenuApi). The landing + order
# pages pull the live menu from {base}/api/menu. If the service isn't running,
# the pages fall back to the bundled sample menu.
VITE_MENU_API_BASE=http://localhost:5100
