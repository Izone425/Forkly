# Forkly frontend — environment configuration
# Copy this file to ".env.local" and fill in values as services come online.
# All keys are OPTIONAL; the landing page renders fine without them.

# URL of the LOGIN page/service (built by another team member).
# When set, the "Login" button redirects here with ?from=forkly-landing&return_to=...&role=...
# Example:
# VITE_LOGIN_URL=http://localhost:8081/login

# Base URL of the auth microservice REST / gRPC-web gateway.
# Only needed if you switch on the API-driven handoff in src/services/authGateway.js.
# Example:
# VITE_AUTH_API_BASE=http://localhost:8080

# Base URL of the ORDER microservice REST / gRPC-web gateway.
# When unset, the order page accepts orders in local "demo" mode (no network call).
# Example:
# VITE_ORDER_API_BASE=http://localhost:8082

# Origin the auth service should return the user to after login.
# Defaults to this app's own origin if left unset.
# VITE_APP_ORIGIN=http://localhost:5173
