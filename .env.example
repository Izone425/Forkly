# Forkly frontend — environment configuration
# Copy this file to ".env.local" to override defaults. All keys are OPTIONAL.

# Base URL of the Forkly .NET API (auth, profile, orders).
# Defaults to http://localhost:5080 (see src/config.js) — only set to override.
# VITE_API_BASE=http://localhost:5080

# Base URL of the ORDER microservice REST / gRPC-web gateway.
# When unset, the order page accepts orders in local "demo" mode (no network call).
# Example:
# VITE_ORDER_API_BASE=http://localhost:8082

# Whether the PAYMENT service/page is ready. Set to "true" once the payment team
# (other branch) ships, and placing an order will auto-redirect to payment.
# Until then, leave unset: the order shows as awaiting payment.
# VITE_PAYMENT_READY=true
