# Forkly frontend — environment configuration
# Copy this file to ".env.local" to override defaults. All keys are OPTIONAL.

# Base URL of the Forkly .NET API (auth, profile, orders).
# Defaults to http://localhost:5080 (see src/config.js) — only set to override.
# VITE_API_BASE=http://localhost:5080

# Base URL of the MENU microservice (Amirul). The landing + order pages pull the
# live menu (name, price, description, picture) from {base}/api/menu.
# When unset, both pages show the bundled fallback menu so the UI still renders.
# Example:
# VITE_MENU_API_BASE=http://localhost:5100

# Base URL of the ORDER microservice (Hanif). Placing an order POSTs to
# {base}/api/orders. When unset, the order page runs in local "demo" mode.
# Example:
# VITE_ORDER_API_BASE=http://localhost:5208

# Base URL of the KITCHEN microservice (Zul). The crew kitchen board (/kitchen)
# reads its queue and pushes crew status changes here.
# Example:
# VITE_KITCHEN_API_BASE=http://localhost:5400

# Base URL of the PAYMENT microservice (Aiman). The payment page starts/settles
# the (mock) payment against {base}/api/payments.
# Example:
# VITE_PAYMENT_API_BASE=http://localhost:5300

# Whether the PAYMENT service/page is ready. Set to "true" so placing an order
# auto-redirects to the payment page. Leave unset to show "awaiting payment".
# VITE_PAYMENT_READY=true

# Base URL of the TRACKER microservice (Alia). The order-tracking page (/track)
# polls this for live status + the mock delivery ETA.
# Example:
# VITE_TRACKER_API_BASE=http://localhost:5500
